---
import Base from './Base.astro'
import '../styles/prose.css'

interface Props {
  title: string
  description: string
  date: string
  tags?: string[]
  author?: string
}

const { title, description, date, tags = [], author } = Astro.props
const formattedDate = new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
---

<Base title={`${title} — Lattices`} description={description}>
  <nav class="post-nav">
    <div class="post-nav-inner">
      <a href="/" class="post-nav-brand">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          {[true, false, false, true, false, false, true, true, true].map((bright, i) => {
            const pad = 2, gap = 1.2, cell = (20 - 2 * pad - 2 * gap) / 3
            const row = Math.floor(i / 3), col = i % 3
            return <rect x={pad + col * (cell + gap)} y={pad + row * (cell + gap)} width={cell} height={cell} rx={1} fill={bright ? '#f2f2f2' : 'rgba(255,255,255,0.18)'} />
          })}
        </svg>
        <span>lattices</span>
      </a>
      <div class="post-nav-links">
        <a href="/blog">Blog</a>
        <a href="/docs/overview">Docs</a>
      </div>
    </div>
  </nav>

  <article class="post-container">
    <a href="/blog" class="post-back">&larr; all posts</a>
    <h1 class="post-title">{title}</h1>
    <div class="post-meta">
      {author && <span>{author} &middot; </span>}
      {formattedDate}
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag: string) => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>

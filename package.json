{
  "name": "@lattices/cli",
  "version": "0.3.0",
  "description": "Agentic window manager for macOS — programmable workspace, smart layouts, managed tmux sessions, and a 35+-method agent API",
  "bin": {
    "lattices": "./bin/lattices.ts",
    "lattices-app": "./bin/lattices-app.ts"
  },
  "keywords": [
    "tmux",
    "claude",
    "dev-server",
    "developer-tools",
    "cli",
    "terminal",
    "multiplexer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arach/lattices"
  },
  "license": "MIT",
  "exports": {
    ".": "./bin/client.ts",
    "./daemon-client": "./bin/daemon-client.ts",
    "./project-twin": "./bin/project-twin.ts"
  },
  "scripts": {
    "dev": "bun --cwd docs-site dev",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "os": ["darwin"],
  "files": [
    "bin",
    "app/Package.swift",
    "app/Sources",
    "app/Lattices.app/Contents/Info.plist",
    "docs"
  ],
  "devDependencies": {
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/xai": "^3.0.67",
    "@arach/speakeasy": "^0.2.8",
    "ai": "^6.0.116"
  }
}

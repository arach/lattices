---
import '../styles/landing.css'

const configExample = `{
  <span class="hl-key">"ensure"</span>: <span class="hl-num">true</span>,
  <span class="hl-key">"panes"</span>: [
    {
      <span class="hl-key">"name"</span>: <span class="hl-str">"claude"</span>,
      <span class="hl-key">"cmd"</span>: <span class="hl-str">"claude"</span>,
      <span class="hl-key">"size"</span>: <span class="hl-num">60</span>
    },
    {
      <span class="hl-key">"name"</span>: <span class="hl-str">"server"</span>,
      <span class="hl-key">"cmd"</span>: <span class="hl-str">"pnpm dev"</span>
    },
    {
      <span class="hl-key">"name"</span>: <span class="hl-str">"tests"</span>,
      <span class="hl-key">"cmd"</span>: <span class="hl-str">"pnpm test --watch"</span>
    }
  ]
}`

const agentExample = `<span class="hl-kw">import</span> { daemonCall } <span class="hl-kw">from</span> <span class="hl-str">'lattices/daemon-client'</span>

<span class="hl-cmt">// Launch a session and tile it</span>
<span class="hl-kw">await</span> daemonCall(<span class="hl-str">'session.launch'</span>, {
  path: <span class="hl-str">'/Users/you/dev/frontend'</span>
})
<span class="hl-kw">await</span> daemonCall(<span class="hl-str">'window.tile'</span>, {
  session: <span class="hl-str">'frontend-a1b2c3'</span>,
  position: <span class="hl-str">'left'</span>
})

<span class="hl-cmt">// Read the screen</span>
<span class="hl-kw">await</span> daemonCall(<span class="hl-str">'ocr.scan'</span>)
<span class="hl-kw">const</span> errors = <span class="hl-kw">await</span> daemonCall(<span class="hl-str">'ocr.search'</span>, {
  query: <span class="hl-str">'error OR failed'</span>
})

<span class="hl-cmt">// See all windows</span>
<span class="hl-kw">const</span> windows = <span class="hl-kw">await</span> daemonCall(<span class="hl-str">'windows.list'</span>)`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>lattices — workspace control plane for macOS</title>

    <meta name="description" content="Persistent terminal sessions, window tiling, and screen text indexing — all controllable from the CLI or a 30-method daemon API. Menu bar app included." />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://lattices.dev/" />
    <meta property="og:title" content="lattices — workspace control plane for macOS" />
    <meta property="og:description" content="Persistent terminal sessions, window tiling, and screen text indexing — all controllable from the CLI or a 30-method daemon API. Menu bar app included." />
    <meta property="og:image" content="https://lattices.dev/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content="lattices — workspace control plane for macOS" />
    <meta property="twitter:description" content="Persistent terminal sessions, window tiling, and screen text indexing — all controllable from the CLI or a 30-method daemon API. Menu bar app included." />
    <meta property="twitter:image" content="https://lattices.dev/og.png" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GSHDZPFRZG"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GSHDZPFRZG');
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="landing">
      <!-- Nav -->
      <nav class="nav">
        <div class="nav-inner">
          <a href="/" class="nav-brand">
            <span class="nav-dot"></span>
            <span class="nav-name">lattices</span>
          </a>
          <div class="nav-links">
            <a href="/docs/overview" class="nav-link">Docs</a>
            <a href="/docs/api" class="nav-link">API</a>
            <a href="#config" class="nav-link">Config</a>
            <a href="#app" class="nav-link">App</a>
            <a href="https://github.com/arach/lattices" target="_blank" rel="noopener noreferrer" class="nav-github">
              <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" /></svg>
              <span class="github-label">GitHub</span>
            </a>
          </div>
        </div>
      </nav>

      <!-- Hero -->
      <div class="shell">
        <section class="hero fade-in">
          <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            Open source · 100% free
          </div>
          <h1>
            Workspace<br />
            <span class="accent">control plane</span>
          </h1>
          <div class="hero-pillars">
            <div class="hero-pillar">
              <h2>Terminal sessions</h2>
              <p>Declare your dev environment in JSON. Lattices builds it, runs it, and keeps it alive across reboots.</p>
            </div>
            <div class="hero-pillar">
              <h2>Window awareness</h2>
              <p>Tile with hotkeys, organize into layers, and search the text on every window — indexed automatically.</p>
            </div>
            <div class="hero-pillar">
              <h2>Programmable desktop</h2>
              <p>30-method daemon API. Your CLI scripts and AI agents control the same desktop you do.</p>
            </div>
          </div>

          <div class="install fade-in fade-in-delay-1">
            <div class="install-tabs">
              <button class="install-tab active" data-pm="npm">npm</button>
              <button class="install-tab" data-pm="pnpm">pnpm</button>
              <button class="install-tab" data-pm="bun">bun</button>
            </div>
            <div class="install-cmd">
              <code><span class="prompt">$</span><span data-cmd>npm install -g lattices</span></code>
              <button class="install-copy" data-copy-btn>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-copy-icon>
                  <rect x="9" y="9" width="13" height="13" rx="2" />
                  <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                </svg>
              </button>
            </div>
            <div class="hero-links">
              <a href="https://github.com/arach/lattices" target="_blank" rel="noopener noreferrer" class="star-link">
                <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z" /></svg>
                Star us on GitHub
              </a>
              <a href="/docs/overview" class="docs-link">Read the docs</a>
            </div>
          </div>
        </section>

        <!-- Config -->
        <section class="section" id="config">
          <div class="config-grid fade-in fade-in-delay-2">
            <div>
              <h2 class="config-title">Persistent terminal sessions</h2>
              <p class="config-desc">
                Drop a <code>.lattices.json</code> in your project root.
                lattices builds your panes, runs your commands, and keeps
                them alive. Reboot, come back a week later — everything
                is where you left it.
              </p>
              <div class="layouts">
                <div class="layout-card">
                  <h3>1 pane</h3>
                  <p>Single focus</p>
                  <div class="layout-diagram layout-1">
                    <div class="layout-pane main">claude</div>
                  </div>
                </div>
                <div class="layout-card">
                  <h3>2 panes</h3>
                  <p>Side-by-side</p>
                  <div class="layout-diagram layout-2">
                    <div class="layout-pane main">claude</div>
                    <div class="layout-pane">server</div>
                  </div>
                </div>
                <div class="layout-card">
                  <h3>3+ panes</h3>
                  <p>Main-vertical</p>
                  <div class="layout-diagram layout-3">
                    <div class="layout-pane main">claude</div>
                    <div class="layout-pane">server</div>
                    <div class="layout-pane">tests</div>
                  </div>
                </div>
              </div>
            </div>

            <div class="code-block">
              <div class="code-header">
                <span class="code-dot code-dot-red"></span>
                <span class="code-dot code-dot-yellow"></span>
                <span class="code-dot code-dot-green"></span>
                <span class="code-filename">.lattices.json</span>
              </div>
              <pre class="code-pre" set:html={configExample} />
            </div>
          </div>
        </section>

        <!-- Agent Control Plane -->
        <section class="section" id="agents">
          <div class="config-grid fade-in fade-in-delay-2">
            <div>
              <h2 class="config-title">A programmable desktop</h2>
              <p class="config-desc">
                The CLI and daemon API expose everything: query what's on screen,
                search window text, tile layouts, manage sessions. Claude Code
                skills, MCP servers, or your own scripts can drive your desktop.
              </p>
              <ul class="agent-methods">
                <li><code>windows.list</code> see every window on screen</li>
                <li><code>ocr.search</code> search text across all windows</li>
                <li><code>session.launch</code> start a project session</li>
                <li><code>window.tile</code> snap windows to screen positions</li>
                <li>30 methods + 5 real-time events over WebSocket</li>
              </ul>
              <a href="/docs/api" class="agent-api-link">Full API reference &rarr;</a>
            </div>

            <div class="code-block">
              <div class="code-header">
                <span class="code-dot code-dot-red"></span>
                <span class="code-dot code-dot-yellow"></span>
                <span class="code-dot code-dot-green"></span>
                <span class="code-filename">agent-example.js</span>
              </div>
              <pre class="code-pre" set:html={agentExample} />
            </div>
          </div>
        </section>

        <!-- Features -->
        <section class="features fade-in fade-in-delay-2" id="features">
          <div class="feature">
            <span class="feature-icon">&#9654;</span>
            <h3>One command</h3>
            <p>Run <code>lattices</code> in any project directory. Session created, panes running, layout applied.</p>
          </div>
          <div class="feature">
            <span class="feature-icon">&#8644;</span>
            <h3>Survives reboots</h3>
            <p>Close your laptop, come back a week later. Reattach and your editor, dev server, and tests are where you left them.</p>
          </div>
          <div class="feature">
            <span class="feature-icon">&#9638;</span>
            <h3>Window tiling</h3>
            <p>Tile with hotkeys, organize into switchable layers, snap to grids. Works across Spaces.</p>
          </div>
          <div class="feature">
            <span class="feature-icon">&#128270;</span>
            <h3>Screen text indexing</h3>
            <p>Reads text from UI elements every 60s. Vision OCR on background windows every 2h. All searchable.</p>
          </div>
          <div class="feature">
            <span class="feature-icon">&#9881;</span>
            <h3>30 RPC methods</h3>
            <p>WebSocket daemon on localhost. Windows, sessions, tiling, layers, screen text. Anything the app does, your agent can do.</p>
          </div>
          <div class="feature">
            <span class="feature-icon">&#9783;</span>
            <h3>Zero config</h3>
            <p>No <code>.lattices.json</code>? It reads your <code>package.json</code> and picks the right dev command automatically.</p>
          </div>
        </section>

        <!-- Menu bar app -->
        <section class="app-section" id="app">
          <div class="app-grid">
            <div>
              <h2 class="app-title">Window tiling and awareness</h2>
              <p class="app-desc">
                A native menu bar app that tracks every window on your desktop.
              </p>
              <ul class="app-features">
                <li>Command palette with <code>Cmd+Shift+M</code></li>
                <li>Window tiling that works across Spaces</li>
                <li><a href="/docs/layers">Workspace layers</a> with <code>Cmd+Option+1/2/3</code></li>
                <li><a href="/docs/layers#tab-groups">Tab groups</a> for related repos</li>
                <li>Screen text extraction via Accessibility API (every 60s)</li>
                <li>Vision OCR for background windows (every 2h)</li>
                <li>Full-text search across all indexed window content</li>
              </ul>
            </div>
            <div class="app-screenshot-wrap">
              <img src="/app-screenshot.png" alt="lattices menu bar app showing a running session" class="app-screenshot" />
            </div>
          </div>
        </section>

        <!-- CTA -->
        <section class="cta">
          <h2>Get started</h2>
          <p>Terminal sessions, window awareness, and a programmable desktop.</p>
          <div class="cta-actions">
            <a href="https://github.com/arach/lattices" target="_blank" rel="noopener noreferrer" class="btn btn-primary">View on GitHub</a>
            <a href="https://www.npmjs.com/package/lattices" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">npm package</a>
            <a href="/docs/api" class="btn btn-secondary">API Reference</a>
          </div>
        </section>

        <!-- Footer -->
        <footer class="footer">
          <span>Built by <a href="https://github.com/arach" target="_blank" rel="noopener noreferrer">@arach</a></span>
          <a href="/docs/overview" class="footer-link">Documentation</a>
          <span>macOS only. tmux optional.</span>
        </footer>
      </div>
    </div>

    <script is:inline>
      (() => {
        const commands = { npm: 'npm install -g lattices', pnpm: 'pnpm add -g lattices', bun: 'bun add -g lattices' }
        const cmdEl = document.querySelector('[data-cmd]')
        const tabs = document.querySelectorAll('.install-tab')
        const copyBtn = document.querySelector('[data-copy-btn]')
        let current = 'npm'

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            current = tab.dataset.pm
            cmdEl.textContent = commands[current]
            tabs.forEach(t => t.classList.remove('active'))
            tab.classList.add('active')
          })
        })

        copyBtn && copyBtn.addEventListener('click', () => {
          navigator.clipboard.writeText(commands[current]).then(() => {
            copyBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>'
            setTimeout(() => {
              copyBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" /></svg>'
            }, 2000)
          })
        })
      })()
    </script>
  </body>
</html>

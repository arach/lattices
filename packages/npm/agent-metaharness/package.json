{
  "name": "@openscout/agent-metaharness",
  "version": "0.0.0",
  "private": true,
  "description": "Run any harnessable agent (pi, codex, claude-code, opencode) via one CLI/SDK over @openscout/agent-sessions adapters. Prototyped in lattices; destined for the openscout repo.",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./catalog": "./src/catalog.mjs"
  },
  "bin": {
    "agent-metaharness": "./bin/agent-metaharness.mjs"
  },
  "files": [
    "src",
    "bin",
    "README.md"
  ],
  "scripts": {
    "smoke:ping": "printf '{\"op\":\"ping\"}\\n' | bun ./bin/agent-metaharness.mjs",
    "smoke:catalog": "printf '{\"op\":\"catalog\"}\\n' | bun ./bin/agent-metaharness.mjs",
    "smoke:pi": "printf '{\"op\":\"start\",\"id\":1,\"sessionId\":\"smoke\",\"harness\":\"pi\",\"provider\":\"openai-codex\"}\\n{\"op\":\"prompt\",\"id\":2,\"sessionId\":\"smoke\",\"text\":\"Reply with exactly: hello\"}\\n' | bun ./bin/agent-metaharness.mjs"
  },
  "keywords": [
    "openscout",
    "agent",
    "harness",
    "metaharness",
    "runtime",
    "sessions"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@openscout/agent-sessions": "0.2.64"
  }
}
